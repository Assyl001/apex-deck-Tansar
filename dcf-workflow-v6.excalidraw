      "boundElements": [],
      "updatedAt": 1776582228027,
      "link": null,
      "locked": false,
      "text": "Source-of-truth model as JSON tree:\n  \u2022 every row = {name, formula_AST,\n    dependencies[], source, value}\n  \u2022 machine-diffable across versions\n  \u2022 sector-tagged (see frameworks \u2193)\n\nExcel is a RENDER of this JSON,\nnot the source itself.\n\nProducer: Engine (deterministic)",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Source-of-truth model as JSON tree:\n  \u2022 every row = {name, formula_AST,\n    dependencies[], source, value}\n  \u2022 machine-diffable across versions\n  \u2022 sector-tagged (see frameworks \u2193)\n\nExcel is a RENDER of this JSON,\nnot the source itself.\n\nProducer: Engine (deterministic)",
      "lineHeight": 1.25,
      "baseline": 11,
      "autoResize": true
    },
